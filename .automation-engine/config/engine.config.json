{
  "_descricao": "Configuração central do Automation Engine",
  "_versao": "2.0.0",

  "engine": {
    "name": "automation-engine",
    "version": "2.0.0",
    "system_mode": "automatic",
    "_system_mode_opcoes": {
      "automatic": "Motor decide o modo por tarefa baseado nas regras",
      "manual_only": "Força modo manual para TODAS as tarefas",
      "disabled": "Motor pausado"
    }
  },

  "stack": {
    "frontend": "React + TypeScript",
    "backend": "Node.js + TypeScript",
    "test_runner": "auto-detect",
    "_test_runner_nota": "auto-detect verifica vitest.config ou jest.config no projeto"
  },

  "retry": {
    "max_retries": 3,
    "_nota": "Máximo de tentativas antes de escalar para o usuário"
  },

  "timeouts": {
    "max_task_age_hours": 24,
    "manual_confirmation_timeout_minutes": 60
  },

  "paths": {
    "incoming": ".automation-engine/tasks/incoming",
    "processing": ".automation-engine/tasks/processing",
    "completed": ".automation-engine/tasks/completed",
    "failed": ".automation-engine/tasks/failed",
    "logs": ".automation-engine/logs"
  },

  "typescript_rules": {
    "allow_any": false,
    "require_explicit_types": true,
    "require_loading_state": true,
    "require_error_state": true,
    "interfaces_location": "src/types or src/interfaces"
  },

  "test_rules": {
    "generate_tests": true,
    "tests_before_human_approval": false,
    "_nota": "Testes só são gerados após aprovação humana em modo manual"
  },

  "subtask_rules": {
    "generate_subtasks": true,
    "generate_at": "end_only",
    "_nota": "Subtarefas geradas SOMENTE no final, após testes passando"
  }
}
